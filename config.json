{
  "project_info": {
    "name": "Nuclear Physics AI Project",
    "version": "2.0.0",
    "description": "AI/ANFIS-based predictions for nuclear magnetic moments and quadrupole moments",
    "author": "Kemal Bey",
    "date": "2025-11-21"
  },

  "data": {
    "input_file": "aaa2.txt",
    "total_nuclei": 267,
    "features": 44,
    "targets": ["MM", "QM", "Beta_2", "MM_QM"]
  },

  "pfaz01_dataset_generation": {
    "enabled": true,
    "dataset_sizes": [75, 100, 150, 200, 267],
    "targets": ["MM", "QM", "MM_QM", "Beta_2"],
    "qm_filtering": {
      "enabled": true,
      "strategies": ["even_even", "odd_A", "odd_odd"]
    },
    "theoretical_calculations": {
      "semf": true,
      "woods_saxon": true,
      "nilsson": true,
      "shell_effects": true
    }
  },

  "pfaz02_ai_training": {
    "enabled": true,
    "models": ["RF", "GBM", "XGBoost", "DNN", "BNN", "PINN"],
    "n_configurations": 50,
    "hyperparameter_optimization": {
      "method": "grid_search",
      "cv_folds": 5
    },
    "parallel_training": {
      "enabled": true,
      "n_workers": 4
    },
    "gpu": {
      "enabled": true,
      "device": "cuda:0"
    }
  },

  "pfaz03_anfis_training": {
    "enabled": true,
    "matlab_engine": {
      "enabled": false,
      "fallback_python": true
    },
    "configurations": [
      "gridpartition_trimf",
      "gridpartition_gaussmf",
      "gridpartition_gbellmf",
      "gridpartition_trapmf",
      "subclust_trimf",
      "subclust_gaussmf",
      "fcm_trimf",
      "fcm_gaussmf"
    ],
    "parallel_training": {
      "enabled": true,
      "n_workers": 4
    }
  },

  "pfaz04_unknown_predictions": {
    "enabled": true,
    "extrapolation_regions": ["drip_line", "superheavy", "neutron_rich", "proton_rich"],
    "uncertainty_quantification": true,
    "confidence_level": 0.95
  },

  "pfaz05_cross_model_analysis": {
    "enabled": true,
    "nucleus_classification": {
      "good_threshold": 0.90,
      "medium_threshold": 0.80
    }
  },

  "pfaz06_final_reporting": {
    "enabled": true,
    "excel_reports": {
      "enabled": true,
      "n_sheets": 18
    },
    "latex_reports": {
      "enabled": true,
      "auto_compile": false
    }
  },

  "pfaz07_ensemble": {
    "enabled": true,
    "voting_methods": ["simple", "weighted_r2", "weighted_rmse", "weighted_mae", "inverse_error"],
    "stacking_methods": ["ridge", "lasso", "elasticnet", "rf", "gbm", "mlp"],
    "cv_folds": 5
  },

  "pfaz08_visualization": {
    "enabled": true,
    "output_formats": ["png", "html"],
    "dpi": 300,
    "n_plots_expected": 80
  },

  "pfaz09_aaa2_monte_carlo": {
    "enabled": true,
    "monte_carlo": {
      "n_runs": 1000,
      "noise_level": 0.05,
      "confidence_level": 0.95
    },
    "pivot_tables": 8
  },

  "pfaz10_thesis_compilation": {
    "enabled": true,
    "latex": {
      "main_file": "thesis_main.tex",
      "chapters": 6,
      "figures": 80,
      "tables": 30,
      "references": 80
    },
    "pdf_compilation": {
      "enabled": false,
      "engine": "pdflatex",
      "passes": 3
    }
  },

  "pfaz11_production_deployment": {
    "enabled": false,
    "note": "Skipped as per user request",
    "web_interface": false,
    "api_endpoints": false,
    "docker": false
  },

  "pfaz12_advanced_analytics": {
    "enabled": true,
    "statistical_tests": ["paired_t_test", "wilcoxon", "friedman"],
    "bootstrap": {
      "n_samples": 10000,
      "confidence_level": 0.95
    },
    "sensitivity_analysis": {
      "methods": ["OAT", "sobol", "morris"]
    }
  },

  "pfaz13_automl": {
    "enabled": true,
    "frameworks": ["optuna", "auto_sklearn", "tpot"],
    "optimization": {
      "n_trials": 1000,
      "timeout_hours": 12,
      "pruning": true
    },
    "feature_engineering": {
      "polynomial_features": true,
      "interaction_features": true,
      "feature_selection": true
    }
  },

  "paths": {
    "data_dir": "data/",
    "output_dir": "outputs/",
    "models_dir": "models/",
    "logs_dir": "logs/",
    "thesis_dir": "thesis/",
    "visualizations_dir": "visualizations/"
  },

  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "logs/main.log",
    "console": true
  },

  "performance": {
    "target_metrics": {
      "r2_min": 0.90,
      "r2_target": 0.95,
      "rmse_max": 0.15,
      "mae_max": 0.10
    }
  },

  "system": {
    "python_version": "3.8+",
    "cuda_version": "11.0+",
    "ram_required_gb": 16,
    "gpu_memory_gb": 8,
    "disk_space_gb": 50
  }
}
